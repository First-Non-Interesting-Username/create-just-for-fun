{
  "name": "Create: Just for Fun developement",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu@sha256:d1fc409bd576f7b6f81c5cfd7399ac8b26d0fd80ba0d2eb269b1e6e1f151d22b",
  "features": {
    "ghcr.io/devcontainers/features/go:1": {
      "version": "latest"
    }
  },
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/workspaces/create-just-for-fun/.devcontainer/bin"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "WakaTime.vscode-wakatime",
        "tamasfe.even-better-toml",
        "eamodio.gitlens"
      ]
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y && go install github.com/packwiz/packwiz@latest"
}